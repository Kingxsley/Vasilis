# MongoDB Connection String (required)
# Get from MongoDB Atlas: https://cloud.mongodb.com
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/vasilisnetshield?retryWrites=true&w=majority

# Database name
DB_NAME=vasilisnetshield

# JWT Secret - use a long random string
JWT_SECRET=your-super-secret-jwt-key-change-this

# CORS Origins - your frontend domain(s)
CORS_ORIGINS=https://vasilisnetshield.net,https://www.vasilisnetshield.net

# Optional: OpenAI API key for AI-generated content
# OPENAI_API_KEY=sk-...

# Optional: SMTP for sending phishing simulation emails
# SMTP_HOST=smtp.sendpulse.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASSWORD=your-smtp-password

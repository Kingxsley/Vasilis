## ===========================================
## NETSHIELD BACKEND ENVIRONMENT VARIABLES
## ===========================================

## DATABASE (Required)
## Get free MongoDB at: https://mongodb.com/atlas
MONGO_URL="mongodb+srv://username:password@cluster.mongodb.net/vasilisnetshield?retryWrites=true&w=majority"
DB_NAME="vasilisnetshield"

## SECURITY (Required)
## Generate random string: openssl rand -hex 32
JWT_SECRET="change-this-to-a-random-secret-key"

## CORS (Required for production)
## Your Vercel frontend URL
CORS_ORIGINS="https://your-app.vercel.app"

## ===========================================
## SMTP - SendPulse Configuration (Optional)
## ===========================================
## Required for sending real phishing simulation emails
## Sign up at: https://sendpulse.com/
## Go to: Settings → SMTP → Get SMTP credentials

# SMTP_HOST="smtp-pulse.com"
# SMTP_PORT=465
# SMTP_USER="your-sendpulse-login-email"
# SMTP_PASSWORD="your-sendpulse-smtp-password"
# SMTP_USE_SSL=true

## ===========================================
## Alternative SMTP - Gmail (Optional)
## ===========================================
## Enable 2FA on Gmail, then create App Password:
## https://myaccount.google.com/apppasswords

# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your-email@gmail.com"
# SMTP_PASSWORD="your-16-char-app-password"
# SMTP_USE_SSL=false


# Backend Environment Variables for Vercel
# Copy these to your Vercel project settings

# MongoDB Connection (use MongoDB Atlas for Vercel)
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/vasilisnetshield?retryWrites=true&w=majority
DB_NAME=vasilisnetshield

# CORS - Set to your frontend domain
CORS_ORIGINS=https://vasilisnetshield.com

# JWT Secret - Use a strong random string
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# SendGrid for emails
SENDGRID_API_KEY=your-sendgrid-api-key
SENDER_EMAIL=info@vasilisnetshield.com

# Frontend URL for email links
FRONTEND_URL=https://vasilisnetshield.com
